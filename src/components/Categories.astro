---
import { db } from "../db";
import { categories as categoriesSchema } from "../db/schema";

// Obtenemos todas las categorías desde la base de datos Neon
const dbCategories = await db.select().from(categoriesSchema);
---

<section class="w-full max-w-[1400px] mx-auto py-16 px-4 md:px-8">
  <div class="text-center mb-6 md:mb-12">
    <h2 class="text-[18px] md:text-3xl font-bold text-[#0d1624] uppercase tracking-widest relative inline-block pb-4">
      Nuestras Categorías
      <span class="absolute bottom-0 left-1/2 transform -translate-x-1/2 w-16 h-1 bg-[#f04f23]"></span>
    </h2>
  </div>
  
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {dbCategories.map((category) => (
      <a href={`/categorias/${category.slug}`} class="group flex flex-col h-full border border-gray-200 bg-white hover:border-[#f04f23] transition-colors duration-300">
        <div class="p-6 lg:p-8 flex flex-col h-full">
          <h3 class="text-[11px] md:text-[13px] font-bold text-gray-900 text-center uppercase tracking-wider mb-6 pb-4 border-b border-gray-100 group-hover:text-[#f04f23] transition-colors min-h-[48px] flex items-center justify-center">
            {category.name}
          </h3>
          
          <div class="w-full flex-1 flex items-center justify-center mb-6 md:mb-8 min-h-[120px] md:min-h-[180px] max-h-[160px] md:max-h-[220px]">
            <img 
              src={category.imageUrl} 
              alt={category.name} 
              class="max-w-full max-h-[140px] md:max-h-[200px] object-contain group-hover:opacity-90 transition-opacity"
              onerror="this.style.display='none'"
            />
          </div>

          <div class="w-full bg-[#1e1a17] text-white text-center font-bold py-2.5 text-xs tracking-wide group-hover:bg-[#f04f23] transition-colors duration-300 mt-auto">
            VER MÁS
          </div>
        </div>
      </a>
    ))}
  </div>
</section>
