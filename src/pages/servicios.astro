---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.tsx";
import PageHeader from "../components/PageHeader.astro";
import { db } from "../db";
import { services } from "../db/schema";
import { asc } from "drizzle-orm";

const dbServices = await db.select().from(services).orderBy(asc(services.order), asc(services.id));
---

<Layout 
  title="Servicios y Mantenimiento | Heat Factory"
  description="Mantenimiento preventivo, correctivo y automatización de sistemas térmicos. Servicio técnico especializado 24/7 en todo el Perú."
>
  <Header client:load />
  
  <PageHeader 
    title="NUESTROS SERVICIOS"
    breadcrumbs={[
      { name: "INICIO", url: "/" },
      { name: "SERVICIOS" }
    ]}
    bgImage="/bc-servicios.avif"
  />

  <main class="max-w-[1200px] mx-auto pt-4 pb-0 md:pt-8 md:pb-12 lg:py-12 px-4 md:px-8">
    
    {dbServices.map((service, index) => {
      const isEven = index % 2 === 0;
      return (
        <>
          <div class={`grid grid-cols-1 ${isEven ? 'md:grid-cols-[45%_1fr]' : 'md:grid-cols-[1fr_45%]'} gap-4 sm:gap-6 md:gap-10 lg:gap-10 items-stretch`}>
            
            {/* Imagen */}
            <div class={`w-full rounded-2xl overflow-hidden shadow-md relative group min-h-[200px] sm:min-h-[250px] md:min-h-[280px] lg:min-h-[350px] ${isEven ? '' : 'order-1 md:order-2'}`}>
              <div class="absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors duration-500 z-10 pointer-events-none"></div>
              <img 
                src={service.imageUrl} 
                alt={service.title} 
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                onerror="this.src='https://placehold.co/800x600/eeeeee/999999?text=Sube+tu+imagen'"
              />
            </div>

            {/* Texto */}
            <div class={`flex flex-col justify-center pt-1 px-2 md:px-0 ${isEven ? '' : 'order-2 md:order-1'}`}>
              <h2 
                class="text-[16px] sm:text-[18px] md:text-[20px] lg:text-[24px] font-bold text-[#0d1624] tracking-tight uppercase leading-[1.3] mb-3 md:mb-4" 
                set:html={service.title.replace(/\n/g, '<br class="hidden md:block"/>')} 
              />
              <div class="w-14 h-[3px] bg-[#f04f23] mb-4 md:mb-5"></div>
              
              <div class="space-y-3 md:space-y-4 text-gray-600 text-[13px] md:text-[14px] leading-relaxed text-justify md:text-left">
                {service.description.split('\n').filter(p => p.trim() !== '').map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </div>
            </div>

          </div>
          
          {index < dbServices.length - 1 && (
            <div class="w-full h-px bg-gradient-to-r from-transparent via-slate-200 to-transparent my-4 sm:my-6 md:my-8 lg:my-10"></div>
          )}
        </>
      );
    })}

    {dbServices.length === 0 && (
      <div class="text-center py-20 text-gray-500">
        <p>Aún no hay servicios registrados en la base de datos.</p>
      </div>
    )}

  </main>
</Layout>
