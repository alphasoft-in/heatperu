---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.tsx";
import PageHeader from "../components/PageHeader.astro";
---

<Layout 
  title="Contacto | Heat Factory"
  description="Contáctanos para soluciones en sistemas térmicos. Cotiza calderas, quemadores y servicios industriales en todo el Perú."
>
  <Header client:load />
  
  <PageHeader 
    title="CONTACTO"
    breadcrumbs={[
      { name: "INICIO", url: "/" },
      { name: "CONTACTO" }
    ]}
    bgImage="/bc-servicios.avif"
  />

  <main class="max-w-[1200px] mx-auto pt-6 pb-0 md:pt-8 md:pb-8 lg:pt-8 lg:pb-2 px-4 md:px-8">
    
    <!-- Removed redundant header -->

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 lg:gap-10">
      
      {/* Información de Contacto (Izquierda) */}
      <div class="lg:col-span-2 flex flex-col justify-center space-y-4 md:space-y-4 lg:space-y-4 h-full">
        
        {/* Tarjeta: Dirección */}
        <div class="flex flex-col items-center text-center md:flex-row md:text-left md:items-start gap-4 md:gap-5 bg-slate-50 p-4 md:p-6 rounded-2xl border border-slate-100 hover:shadow-md transition-shadow">
          <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 bg-white rounded-full flex items-center justify-center text-[#f04f23] shadow-sm">
            <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          </div>
          <div>
            <h3 class="font-bold text-[#0d1624] text-[14px] md:text-[16px] mb-1 md:mb-1.5 uppercase tracking-wide">Dirección</h3>
            <p class="text-slate-600 text-[13px] md:text-[14px] leading-relaxed">
              Av. Argentina 575 Tienda H12 - 13<br/>
              Urb. Lima Industrial - Cercado de Lima
            </p>
          </div>
        </div>

        {/* Tarjeta: Teléfonos */}
        <div class="flex flex-col items-center text-center md:flex-row md:text-left md:items-start gap-4 md:gap-5 bg-slate-50 p-4 md:p-6 rounded-2xl border border-slate-100 hover:shadow-md transition-shadow">
          <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 bg-white rounded-full flex items-center justify-center text-[#f04f23] shadow-sm">
            <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
          </div>
          <div>
            <h3 class="font-bold text-[#0d1624] text-[14px] md:text-[16px] mb-1 md:mb-1.5 uppercase tracking-wide">Contacto</h3>
            <p class="text-slate-600 text-[13px] md:text-[14px] leading-relaxed">
              Celular : +51 961-749-562<br/>
              Celular : +51 967-083-176<br/>
              Celular : +51 908-943-214
            </p>
          </div>
        </div>

        {/* Tarjeta: Email */}
        <div class="flex flex-col items-center text-center md:flex-row md:text-left md:items-start gap-4 md:gap-5 bg-slate-50 p-4 md:p-6 rounded-2xl border border-slate-100 hover:shadow-md transition-shadow">
          <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 bg-white rounded-full flex items-center justify-center text-[#f04f23] shadow-sm">
            <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          </div>
          <div>
            <h3 class="font-bold text-[#0d1624] text-[14px] md:text-[16px] mb-1 md:mb-1.5 uppercase tracking-wide">Correo Electrónico</h3>
            <p class="text-slate-600 text-[13px] md:text-[14px] leading-relaxed">
              ventas@heatperu.com
            </p>
          </div>
        </div>

        {/* Tarjeta: Horario */}
        <div class="flex flex-col items-center text-center md:flex-row md:text-left md:items-start gap-4 md:gap-5 bg-slate-50 p-4 md:p-6 rounded-2xl border border-slate-100 hover:shadow-md transition-shadow">
          <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 bg-white rounded-full flex items-center justify-center text-[#f04f23] shadow-sm">
            <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <div>
            <h3 class="font-bold text-[#0d1624] text-[14px] md:text-[16px] mb-1 md:mb-1.5 uppercase tracking-wide">Horario</h3>
            <p class="text-slate-600 text-[13px] md:text-[14px] leading-relaxed">
              Lunes a Viernes de 9:00am - 6:00pm<br/>
              Sábados de 9:00am - 3:00pm
            </p>
          </div>
        </div>
      </div>

      {/* Formulario de Contacto (Derecha) */}
      <div class="lg:col-span-3">
        <form class="bg-white p-6 md:p-10 rounded-[2rem] shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 mb-4 md:mb-6">
            <div>
              <label class="block text-[13px] font-semibold text-slate-700 mb-2">Nombres Completos *</label>
              <input type="text" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#f04f23] focus:border-transparent transition-all text-[14px]" placeholder="Ej: Juan Pérez" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-slate-700 mb-2">Empresa (Opcional)</label>
              <input type="text" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#f04f23] focus:border-transparent transition-all text-[14px]" placeholder="Nombre de tu empresa" />
            </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div>
              <label class="block text-[13px] font-semibold text-slate-700 mb-2">Correo Electrónico *</label>
              <input type="email" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#f04f23] focus:border-transparent transition-all text-[14px]" placeholder="correo@empresa.com" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-slate-700 mb-2">Teléfono *</label>
              <input type="tel" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#f04f23] focus:border-transparent transition-all text-[14px]" placeholder="+51 999 999 999" />
            </div>
          </div>

          <div class="mb-6">
            <label class="block text-[13px] font-semibold text-slate-700 mb-2">Asunto *</label>
            <input type="text" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#f04f23] focus:border-transparent transition-all text-[14px]" placeholder="¿En qué podemos ayudarte?" />
          </div>

          <div class="mb-8">
            <label class="block text-[13px] font-semibold text-slate-700 mb-2">Mensaje *</label>
            <textarea required rows="5" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#f04f23] focus:border-transparent transition-all text-[14px] resize-none" placeholder="Escribe los detalles de tu consulta aquí..."></textarea>
          </div>

          <button type="submit" class="w-full bg-[#0d1624] text-white font-bold text-[14px] md:text-[15px] py-3 md:py-4 rounded-xl shadow-lg hover:bg-[#1a2538] hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex items-center justify-center gap-2 cursor-pointer">
            <span>Enviar Mensaje</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </button>
        </form>
      </div>

    </div>
  </main>

  {/* Mapa de Ubicación */}
  <div class="w-full h-[350px] md:h-[500px] mt-6 -mb-8 md:-mb-16 relative z-10">
    <iframe 
      src="https://maps.google.com/maps?q=Av.%20Argentina%20575,%20Cercado%20de%20Lima,%20Peru&t=&z=15&ie=UTF8&iwloc=&output=embed" 
      width="100%" 
      height="100%" 
      style="border:0;" 
      allowfullscreen="" 
      loading="lazy" 
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </div>

</Layout>
