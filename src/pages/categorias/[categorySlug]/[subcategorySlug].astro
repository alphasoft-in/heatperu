---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.tsx";
import PageHeader from "../../../components/PageHeader.astro";
import { db } from "../../../db";
import { categories, subcategories, products } from "../../../db/schema";
import { eq, and } from "drizzle-orm";

const { categorySlug, subcategorySlug } = Astro.params;

if (!categorySlug || !subcategorySlug) {
  return Astro.redirect('/');
}

// 1. Buscamos la categoría y la subcategoría dinámica por su slug
const catResult = await db.select().from(categories).where(eq(categories.slug, categorySlug)).limit(1);
if (catResult.length === 0) {
  return Astro.redirect('/404');
}
const category = catResult[0];

const subcatResult = await db.select().from(subcategories).where(
  and(
    eq(subcategories.slug, subcategorySlug),
    eq(subcategories.categoryId, category.id)
  )
).limit(1);

if (subcatResult.length === 0) {
  return Astro.redirect('/404');
}
const subcategory = subcatResult[0];

// 2. Traemos todos sus productos
const dbProductos = await db.select().from(products).where(eq(products.subcategoryId, subcategory.id));

---

<Layout>
  <Header client:load />

  <PageHeader 
    title={subcategory.name.toUpperCase()}
    breadcrumbs={[
      { name: "INICIO", url: "/" },
      { name: category.name.toUpperCase(), url: `/categorias/${category.slug}` }
    ]}
    bgImage="/productos/bc-productos.webp"
  />

  <main class="max-w-[1400px] mx-auto pt-6 pb-2 md:py-16 px-4 md:px-8">
    
    <div class="mb-12 text-center md:text-left hidden">
    </div>

    {dbProductos.length > 0 ? (
      <div class="flex flex-wrap justify-center gap-6 lg:gap-8">
        {dbProductos.map((producto) => (
          <a href={`/productos/${producto.slug}`} class="w-full sm:w-[300px] lg:w-[280px] flex-none group flex flex-col h-full border border-gray-200 bg-white hover:border-[#f04f23] transition-colors duration-300">
            <div class="p-5 flex flex-col h-full">
              <h3 class="text-xs md:text-[13px] font-bold text-gray-900 text-center uppercase tracking-wider mb-4 pb-3 border-b border-gray-100 group-hover:text-[#f04f23] transition-colors line-clamp-2 min-h-[38px] flex items-center justify-center">
                {producto.name}
              </h3>
              
              <div class="w-full flex-1 flex items-center justify-center mb-4 min-h-[130px] max-h-[150px]">
                <img 
                  src={producto.imageUrl} 
                  alt={producto.name} 
                  class="max-w-full max-h-[130px] object-contain group-hover:opacity-90 transition-opacity"
                  onerror="this.style.display='none'"
                />
              </div>

              <div class="w-full bg-gray-50 border-t border-b border-gray-100 py-2.5 mb-4 text-[11px] text-center mt-auto">
                <span class="block text-gray-500 mb-0.5">SKU: <strong class="text-gray-900">{producto.sku}</strong></span>
                <span class="block text-gray-500">MARCA: <strong class="text-gray-900">{producto.brand}</strong></span>
              </div>

              <div class="w-full bg-[#1e1a17] text-white text-center font-bold py-2.5 text-xs tracking-wide group-hover:bg-[#f04f23] transition-colors duration-300">
                VER FICHA
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-20 text-gray-500">
        <svg class="mx-auto h-12 w-12 text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
        <p class="text-lg font-medium">Aún no hay productos disponibles en esta subcategoría.</p>
      </div>
    )}

  </main>
</Layout>
