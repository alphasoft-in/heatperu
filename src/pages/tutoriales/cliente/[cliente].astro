---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.jsx';
import PageHeader from '../../../components/PageHeader.astro';
import { db } from '../../../db';
import { tutorials, tutorialCategories } from '../../../db/schema';
import { eq, asc, desc } from 'drizzle-orm';

export async function getStaticPaths() {
  const cats = await db.select().from(tutorialCategories);
  return cats.map((cat) => ({
    params: { cliente: cat.slug },
  }));
}

const { cliente } = Astro.params;

const currentCat = await db.select().from(tutorialCategories).where(eq(tutorialCategories.slug, cliente)).limit(1);
if (!currentCat || currentCat.length === 0) {
  return Astro.redirect('/404');
}
const cat = currentCat[0];

const subTutorials = await db.select().from(tutorials)
  .where(eq(tutorials.categoryId, cat.id))
  .orderBy(desc(tutorials.executionDate), asc(tutorials.order));

function stripMarkdown(md: string) {
  if (!md) return '';
  return md.replace(/[#*`_\[\]()]/g, '').replace(/\n/g, ' ').trim();
}

function getYouTubeId(url: string) {
  if (!url) return null;
  const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:embed\/|v\/|watch\?v=|watch\?.+&v=))([^&?]+)/);
  return match ? match[1] : null;
}

function formatDate(dateStr: string) {
  if (!dateStr) return '';
  const date = new Date(dateStr);
  return date.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title={`${cat.name} | Trabajos | Heat Factory`}>
  <Header client:load />
  
  <PageHeader 
    title={cat.name.toUpperCase()}
    breadcrumbs={[
      { name: "INICIO", url: "/" },
      { name: "CLIENTES", url: "/tutoriales" },
      { name: cat.name.toUpperCase(), url: `/tutoriales/cliente/${cat.slug}` }
    ]}
    bgImage="/bc-servicios.jpeg"
    bgPosition="object-center"
  />

  <main class="max-w-7xl mx-auto px-4 md:px-8 py-16">
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-1 h-6 bg-[#f04f23] rounded-full"></div>
        <h2 class="text-2xl font-bold text-slate-800">Trabajos para {cat.name}</h2>
        <div class="flex-1 h-px bg-gray-100 ml-2"></div>
      </div>
      <p class="text-slate-500 text-lg">
        Encuentra todos los videos de los trabajos realizados para el cliente {cat.name}.
      </p>
    </div>

    {subTutorials.length === 0 ? (
      <div class="text-center py-20 text-gray-500 bg-gray-50 rounded-2xl border border-dashed border-gray-200">
        <p>Aún no hay trabajos registrados para este cliente. ¡Vuelve pronto!</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {subTutorials.map((tutorial) => {
          const videoId = getYouTubeId(tutorial.videoUrl);
          const thumbnailUrl = tutorial.imageUrl || (videoId ? `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg` : '/placeholder.png');
          return (
            <div class="bg-white rounded-xl border border-gray-100 shadow-[0_4px_20px_rgba(0,0,0,0.04)] overflow-hidden flex flex-col group hover:shadow-[0_12px_40px_rgba(0,0,0,0.08)] transition-all duration-500">
              <a href={`/tutoriales/${tutorial.id}`} class="block relative w-full h-52 bg-white overflow-hidden border-b border-gray-100">
                <img
                  src={thumbnailUrl}
                  alt={tutorial.title}
                  class="w-full h-full object-contain p-8 transition-all duration-700 group-hover:scale-105"
                  onerror="this.src='https://placehold.co/600x400/eeeeee/999999?text=Trabajo'"
                />
              </a>

              <div class="p-6 flex-1 flex flex-col">
                <h3 class="text-base font-semibold text-slate-800 leading-snug mb-3 line-clamp-2 transition-colors duration-300 group-hover:text-[#f04f23]">
                  <a href={`/tutoriales/${tutorial.id}`}>{tutorial.title}</a>
                </h3>

                {tutorial.executionDate && (
                  <div class="flex items-center text-[12px] font-semibold tracking-wide text-slate-500 mb-4 uppercase">
                    <svg class="w-3.5 h-3.5 mr-1.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    {formatDate(tutorial.executionDate)}
                  </div>
                )}

                <p class="text-[14px] text-slate-600 leading-relaxed line-clamp-3 mb-6 flex-1">
                  {stripMarkdown(tutorial.description)}
                </p>

                <div class="pt-4 border-t border-gray-100 mt-auto">
                  <a href={`/tutoriales/${tutorial.id}`} class="flex items-center text-[#f04f23] font-medium text-sm tracking-wide">
                    VER TRABAJO
                    <span class="transform transition-transform duration-300 group-hover:translate-x-2 ml-2">→</span>
                  </a>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    )}
    
    <div class="mt-16 flex justify-center">
      <a href="/tutoriales" class="inline-flex items-center px-6 py-3 border border-gray-300 text-gray-700 font-semibold rounded-lg hover:bg-gray-50 transition-colors">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Volver a la lista de Clientes
      </a>
    </div>
  </main>
</Layout>
