---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.tsx";
import PageHeader from "../../components/PageHeader.astro";
import { db } from "../../db";
import { tutorials } from "../../db/schema";
import { eq } from "drizzle-orm";
import { marked } from "marked";

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/tutoriales');
}

const tutorialId = parseInt(id);
let tutorial;

if (!isNaN(tutorialId) && String(tutorialId) === id) {
  tutorial = await db.query.tutorials.findFirst({
    where: eq(tutorials.id, tutorialId)
  });
} else {
  tutorial = await db.query.tutorials.findFirst({
    where: eq(tutorials.slug, id)
  });
}

if (!tutorial) {
  return Astro.redirect('/tutoriales');
}

// Update views count
await db.update(tutorials)
  .set({ views: tutorial.views + 1 })
  .where(eq(tutorials.id, tutorial.id));

tutorial.views += 1;

function formatDate(dateStr: string | null) {
  if (!dateStr) return '';
  const parts = dateStr.split('-');
  if (parts.length === 3) {
    return `${parts[2]}/${parts[1]}/${parts[0]}`;
  }
  return dateStr;
}

const getYouTubeId = (url: string) => {
  const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/;
  const match = url.match(regExp);
  return (match && match[2].length === 11) ? match[2] : null;
};

const videoId = getYouTubeId(tutorial.videoUrl);
const thumbnailUrl = tutorial.imageUrl || (videoId ? `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg` : '/placeholder.png');

let descriptionHtml = marked.parse(tutorial.description, { breaks: true, gfm: true });
if (typeof descriptionHtml === 'string') {
  descriptionHtml = descriptionHtml
    .replace(/<p>(?:<br\s*\/?>|\s|&nbsp;)*<\/p>/gi, '') // Remove empty paragraphs 
    .replace(/(<br\s*\/?>\s*){2,}/gi, '<br/>') // Replace multiple <br> with single
    .trim();
}
---

<Layout 
  title={`${tutorial.title} | Tutorial | Heat Factory`}
  description={tutorial.description ? tutorial.description.substring(0, 160) : `Tutorial sobre ${tutorial.title} en Heat Factory.`}
  image={tutorial.imageUrl}
>
  <Header client:load />
  
  <PageHeader 
    title={tutorial.title.toUpperCase()}
    breadcrumbs={[
      { name: "INICIO", url: "/" },
      { name: "TUTORIALES", url: "/tutoriales" }
    ]}
    bgImage="/bc-servicios.jpeg"
    bgPosition="object-center"
  />

  <main class="max-w-[1000px] mx-auto -mt-8 md:-mt-10 relative z-20 pb-12 px-4 md:px-8">
    <div class="bg-white rounded-3xl shadow-2xl overflow-hidden border border-gray-100 mx-auto">
      <div class="px-8 pt-6 pb-4 md:px-12 md:pt-10 md:pb-6 relative">
        <div class="absolute top-6 right-6 md:top-8 md:right-12 bg-slate-50 border border-slate-100 text-slate-600 px-4 py-1.5 rounded-full shadow-sm flex items-center gap-2 font-semibold text-[13px] tracking-wide z-20">
          <svg class="w-4 h-4 text-[#f04f23]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
          <span>{tutorial.views} vistas</span>
        </div>

        <h2 class="text-3xl md:text-4xl font-extrabold text-[#0d1624] mb-6 leading-tight">
          Resumen del Tutorial
        </h2>

        {tutorial.executionDate && (
          <div class="flex items-center text-[14px] font-medium text-slate-500 mb-2 border-b border-slate-100 pb-4">
            <svg class="w-4 h-4 mr-2 text-[#f04f23]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            Fecha de Ejecución: <span class="ml-1 text-slate-700 font-semibold">{formatDate(tutorial.executionDate)}</span>
          </div>
        )}
        
        <div class="text-slate-600 text-[14px] leading-relaxed md:leading-loose font-normal markdown-body prose max-w-none [&_p:empty]:hidden">
          <div set:html={descriptionHtml} />
        </div>
      </div>

      {/* Video Section */}
      <div class="px-8 pb-8 md:px-16 md:pb-12">
        {videoId ? (
          <div class="relative w-full pb-[56.25%] h-0 bg-black rounded-2xl overflow-hidden shadow-xl border border-slate-200">
            <iframe 
              src={`https://www.youtube.com/embed/${videoId}?autoplay=0&rel=0`}
              class="absolute top-0 left-0 w-full h-full border-0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
              allowfullscreen
            ></iframe>
          </div>
        ) : (
          <div class="w-full h-64 md:h-96 bg-gray-100 rounded-2xl flex flex-col items-center justify-center text-gray-500 border border-slate-200">
            <svg class="w-16 h-16 mb-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <p>No se pudo cargar el video de YouTube.</p>
            <p class="text-sm mt-2">URL: {tutorial.videoUrl}</p>
          </div>
        )}
      </div>
      
      {/* Footer Support */}
      <div class="bg-slate-50 p-6 md:p-8 border-t border-slate-100 flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <h3 class="text-lg font-bold text-slate-800 mb-2">¿Necesitas ayuda adicional?</h3>
          <p class="text-slate-600 text-sm">Nuestro equipo de soporte técnico está disponible para asistirte con la instalación y mantenimiento de tus equipos.</p>
        </div>
        <a href={`https://wa.me/51967083176?text=${encodeURIComponent(`Hola, tengo una consulta sobre el trabajo: ${tutorial.title}`)}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-[15px] font-bold rounded-lg text-white bg-[#f04f23] hover:bg-[#d8401a] transition-all shadow-md hover:shadow-lg whitespace-nowrap">
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Contactar a soporte
        </a>
      </div>
    </div>
    
    <div class="mt-12 flex justify-center">
      <a href="/tutoriales" class="inline-flex items-center px-8 py-4 bg-slate-800 text-white font-bold rounded-xl hover:bg-slate-700 transition-colors shadow-lg group">
        <svg class="w-5 h-5 mr-3 transform transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Volver a Tutoriales
      </a>
    </div>
  </main>
</Layout>
