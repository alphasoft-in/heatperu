---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.tsx";
import PageHeader from "../../components/PageHeader.astro";
import { db } from "../../db";
import { tutorialCategories, tutorials } from "../../db/schema";
import { eq, isNull, desc, asc } from "drizzle-orm";

const categories = await db.select().from(tutorialCategories).orderBy(asc(tutorialCategories.order));

const clientsWithTutorials = await Promise.all(categories.map(async (cat) => {
  const clientTutorials = await db.select()
    .from(tutorials)
    .where(eq(tutorials.categoryId, cat.id))
    .orderBy(desc(tutorials.executionDate), asc(tutorials.order));
  
  return {
    ...cat,
    tutorials: clientTutorials
  };
}));

// Fetch uncategorized tutorials
const uncategorizedTutorials = await db.select()
  .from(tutorials)
  .where(isNull(tutorials.categoryId))
  .orderBy(desc(tutorials.executionDate), asc(tutorials.order));

function formatDate(dateStr: string | null) {
  if (!dateStr) return '';
  const [y, m, d] = dateStr.split('-');
  return `${d}/${m}/${y}`;
}

function stripMarkdown(text: string) {
  if (!text) return '';
  return text
    .replace(/<[^>]*>?/gm, '')
    .replace(/[#*`_~]/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/\n+/g, ' ')
    .trim();
}

const getYouTubeId = (url: string) => {
  const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/;
  const match = url.match(regExp);
  return (match && match[2].length === 11) ? match[2] : null;
};
---

<Layout 
  title="Tutoriales | Heat Factory"
  description="Explora nuestros tutoriales en instalación, mantenimiento y operación de equipos térmicos y calderas industriales."
>
  <Header client:load />

  <PageHeader
    title="TUTORIALES"
    breadcrumbs={[
      { name: "INICIO", url: "/" },
      { name: "TUTORIALES" }
    ]}
    bgImage="/bc-servicios.jpeg"
    bgPosition="object-center"
  />

  <main class="max-w-[1200px] mx-auto pt-4 md:pt-6 lg:pt-6 pb-0 md:pb-6 lg:pb-4 px-4 md:px-8">

    {clientsWithTutorials.length === 0 && uncategorizedTutorials.length === 0 ? (
      <div class="text-center py-20 text-gray-500 bg-gray-50 rounded-2xl border border-dashed border-gray-200">
        <p>Aún no hay trabajos registrados. Estamos trabajando en nuevo contenido.</p>
      </div>
    ) : (
      <div class="space-y-16">
        
        {clientsWithTutorials.length > 0 && (
          <section>
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 md:gap-8">
              {clientsWithTutorials.map((client) => {
                const clientTutorials = client.tutorials;
                if (clientTutorials.length === 0) return null;
                
                const firstTutorial = clientTutorials[0];
                const videoId = getYouTubeId(firstTutorial.videoUrl);
                const thumbnailUrl = firstTutorial.imageUrl || (videoId ? `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg` : '/placeholder.png');

                return (
                  <a href={`/tutoriales/cliente/${client.slug}`} class="bg-white rounded-2xl border border-gray-100 shadow-[0_4px_20px_rgba(0,0,0,0.03)] overflow-hidden flex flex-col group hover:shadow-[0_12px_40px_rgba(0,0,0,0.08)] hover:-translate-y-1 transition-all duration-500">
                    <div class="pt-5 lg:pt-8 pb-2 px-4 md:px-5 lg:px-6 text-center">
                      <h3 class="text-[15px] md:text-[19px] font-bold text-[#0d1624] uppercase tracking-wide">{client.name}</h3>
                    </div>
                    <div class="flex-1 w-full flex items-center justify-center p-4 md:p-5 lg:p-6 bg-white">
                      <img 
                        src={thumbnailUrl} 
                        alt={client.name} 
                        class="w-full h-40 md:h-48 lg:h-56 object-contain transition-transform duration-700 group-hover:scale-105"
                        onerror="this.src='https://placehold.co/600x400/eeeeee/999999?text=Cliente'"
                      />
                    </div>
                    <div class="p-4 md:p-5 lg:p-6 pt-2 md:pt-2 mt-auto">
                      <div class="w-full bg-[#1e1c19] text-white text-center font-bold text-[14px] md:text-[16px] py-2.5 md:py-3.5 rounded-xl group-hover:bg-black transition-colors shadow-md">
                        Ver más
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        )}

        {uncategorizedTutorials.length > 0 && (
          <section>
            {clientsWithTutorials.length > 0 && (
              <div class="flex items-center gap-3 mb-6">
                <div class="w-1 h-6 bg-[#f04f23] rounded-full"></div>
                <h2 class="text-xl font-bold text-slate-800">Otros Trabajos</h2>
                <div class="flex-1 h-px bg-gray-100 ml-2"></div>
              </div>
            )}
            
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
              {uncategorizedTutorials.map((tutorial) => {
                const videoId = getYouTubeId(tutorial.videoUrl);
                const thumbnailUrl = tutorial.imageUrl || (videoId ? `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg` : '/placeholder.png');
                return (
                  <div class="bg-white rounded-xl border border-gray-100 shadow-[0_4px_20px_rgba(0,0,0,0.04)] overflow-hidden flex flex-col group hover:shadow-[0_12px_40px_rgba(0,0,0,0.08)] transition-all duration-500">
                    <a href={`/tutoriales/${tutorial.id}`} class="block relative w-full h-52 bg-white overflow-hidden border-b border-gray-100">
                      <img
                        src={thumbnailUrl}
                        alt={tutorial.title}
                        class="w-full h-full object-contain p-8 transition-all duration-700 group-hover:scale-105"
                        onerror="this.src='https://placehold.co/600x400/eeeeee/999999?text=Trabajo'"
                      />
                    </a>

                    <div class="p-6 flex-1 flex flex-col">
                      <h3 class="text-base font-semibold text-slate-800 leading-snug mb-3 line-clamp-2 transition-colors duration-300 group-hover:text-[#f04f23]">
                        <a href={`/tutoriales/${tutorial.id}`}>{tutorial.title}</a>
                      </h3>

                      {tutorial.executionDate && (
                        <div class="flex items-center text-[12px] font-semibold tracking-wide text-slate-500 mb-4 uppercase">
                          <svg class="w-3.5 h-3.5 mr-1.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                          {formatDate(tutorial.executionDate)}
                        </div>
                      )}

                      <p class="text-[14px] text-slate-600 leading-relaxed line-clamp-3 mb-6 flex-1">
                        {stripMarkdown(tutorial.description)}
                      </p>

                      <div class="pt-4 border-t border-gray-100 mt-auto">
                        <a href={`/tutoriales/${tutorial.id}`} class="flex items-center text-[#f04f23] font-medium text-sm tracking-wide">
                          VER TRABAJO
                          <span class="transform transition-transform duration-300 group-hover:translate-x-2 ml-2">→</span>
                        </a>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </section>
        )}
      </div>
    )}
  </main>
</Layout>

