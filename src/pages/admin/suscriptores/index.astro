---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import SubscriberChart from "../../../components/admin/SubscriberChart.tsx";
import { db } from "../../../db";
import { subscribers } from "../../../db/schema";
import { desc } from "drizzle-orm";
import { Download, Mail, Trash2 } from "lucide-react";

// Fetch data
const allSubscribers = await db
  .select()
  .from(subscribers)
  .orderBy(desc(subscribers.createdAt));

const chartData = allSubscribers.map(s => ({
  createdAt: s.createdAt.toISOString(),
  status: s.status
}));
---

<AdminLayout title="Suscriptores del Boletín">
  <div
    class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4"
  >
    <div>
      <h1 class="text-xl font-semibold text-gray-900 mb-1">
        Suscriptores del Boletín
      </h1>
      <p class="text-gray-500 text-sm">
        Gestiona la lista de correos suscritos desde el pie de página.
      </p>
    </div>

    <div class="flex items-center gap-3">
      <div
        class="bg-blue-50 text-blue-700 px-4 py-2 rounded-lg font-medium text-sm flex items-center gap-2"
      >
        <Mail className="w-4 h-4" />
        {allSubscribers.length} Suscriptores
      </div>

      <a
        href="/api/admin/suscriptores/exportar"
        class="bg-white border border-gray-200 text-gray-700 hover:bg-gray-50 hover:text-gray-900 px-4 py-2 rounded-lg font-medium text-sm flex items-center gap-2 shadow-sm transition-colors"
      >
        <Download className="w-4 h-4" />
        Exportar CSV
      </a>
    </div>
  </div>

  <SubscriberChart client:load data={chartData} />

  <div
    class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden"
  >
    <div class="overflow-x-auto">
      <table class="w-full text-left text-[13px] text-slate-600">
        <thead
          class="bg-slate-50 text-slate-500 font-medium border-b border-slate-200"
        >
          <tr>
            <th class="px-6 py-4">Email</th>
            <th class="px-6 py-4">Fecha de Suscripción</th>
            <th class="px-6 py-4">Estado</th>
            <th class="px-6 py-4 text-right">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {
            allSubscribers.length === 0 ? (
              <tr>
                <td colspan="4" class="px-6 py-12 text-center text-slate-500">
                  <Mail className="w-12 h-12 mx-auto text-slate-300 mb-3" />
                  <p class="text-base font-medium text-slate-900">
                    No hay suscriptores aún
                  </p>
                  <p class="text-sm">
                    Los correos ingresados en el pie de página aparecerán aquí.
                  </p>
                </td>
              </tr>
            ) : (
              allSubscribers.map((sub) => (
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">
                    {sub.email}
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-slate-500">
                    {new Date(sub.createdAt).toLocaleString("es-PE", {
                      timeZone: "America/Lima",
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                      hour: "2-digit",
                      minute: "2-digit",
                    })}
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span
                      class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${
                        sub.status === "Activo"
                          ? "bg-green-100 text-green-800"
                          : "bg-red-100 text-red-800"
                      }`}
                    >
                      {sub.status}
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-right">
                    <button
                      type="button"
                      data-id={sub.id}
                      class="btn-delete text-slate-400 hover:text-red-600 transition-colors cursor-pointer"
                      title="Eliminar suscriptor"
                    >
                      <Trash2 className="w-4 h-4 inline" />
                    </button>
                  </td>
                </tr>
              ))
            )
          }
        </tbody>
      </table>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const deleteButtons = document.querySelectorAll('.btn-delete');
      
      deleteButtons.forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const button = e.currentTarget as HTMLButtonElement;
          const id = button.getAttribute('data-id');
          
          if (!id) return;
          
          if (confirm('¿Está seguro de revocar y eliminar a este suscriptor?')) {
            try {
              button.disabled = true;
              button.classList.add('opacity-50');
              
              const res = await fetch(`/api/admin/suscriptores/${id}`, {
                method: 'DELETE'
              });
              
              if (res.ok) {
                window.location.reload();
              } else {
                alert('Ocurrió un error al intentar eliminar el suscriptor.');
                button.disabled = false;
                button.classList.remove('opacity-50');
              }
            } catch (error) {
              console.error(error);
              alert('Error de red. Intente nuevamente.');
              button.disabled = false;
              button.classList.remove('opacity-50');
            }
          }
        });
      });
    });
  </script>
</AdminLayout>
