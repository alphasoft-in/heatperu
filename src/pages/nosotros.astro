---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.tsx";
import PageHeader from "../components/PageHeader.astro";
---

<Layout 
  title="Nosotros | Heat Factory - Experiencia y Calidad"
  description="Somos una empresa líder en Perú dedicada al suministro, instalación y mantenimiento de equipos térmicos industriales."
>
  <Header client:load />
  
  <PageHeader 
    title="NOSOTROS"
    breadcrumbs={[
      { name: "INICIO", url: "/" },
      { name: "NOSOTROS" }
    ]}
    bgImage="/bc-servicios.jpeg"
  />

  <main class="max-w-[1200px] mx-auto pt-8 pb-0 md:py-10 lg:pt-10 lg:pb-4 px-4 md:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 items-center">
      
      {/* Columna Izquierda: Imagen */}
      <div class="relative w-full rounded-3xl overflow-hidden shadow-[0_20px_50px_rgb(0,0,0,0.1)] group border-[6px] border-white">
        <div class="absolute inset-0 bg-gradient-to-t from-[#0d1624]/60 via-transparent to-transparent z-10 pointer-events-none opacity-60 group-hover:opacity-40 transition-opacity duration-500"></div>
        <img 
          src="/nosotros.jpeg" 
          alt="Equipo y maquinaria de Heat Factory" 
          class="w-full h-[300px] md:h-[550px] object-cover transform transition-transform duration-700 group-hover:scale-105"
          onerror="this.src='https://placehold.co/600x550/eeeeee/999999?text=Sube+nosotros.jpeg'"
        />
      </div>

      {/* Columna Derecha: Texto */}
      <div class="flex flex-col justify-center items-center md:items-start text-center md:text-left">
        <h2 class="text-[24px] lg:text-[28px] font-black text-[#0d1624] tracking-tight uppercase mb-3 md:mb-4">
          SOBRE NOSOTROS
        </h2>
        <div class="w-16 h-[3px] bg-[#f04f23] mb-5 lg:mb-8 mx-auto md:mx-0"></div>
        
        <p class="font-bold text-[#0d1624] text-[16px] lg:text-[19px] mb-4 lg:mb-6 leading-tight">
          Innovación y Excelencia en Quemadores y Calderas
        </p>

        <div class="space-y-4 lg:space-y-6 text-slate-600 leading-relaxed text-[15px] lg:text-[16px]">
          <p>
            En <strong class="text-[#0d1624]">Heat Factory</strong> nos especializamos en la generación, distribución y uso eficiente de la energía en procesos termodinámicos.
          </p>
          <p>
            Somos importadores directos y distribuidores oficiales de las principales marcas de equipos y repuestos para calderas de vapor, aceite térmico y quemadores.
          </p>
        </div>

        {/* Años de experiencia */}
        <div class="mt-6 lg:mt-10 inline-flex items-center justify-center gap-4 lg:gap-5 bg-slate-50 border border-slate-100 rounded-2xl p-4 lg:p-6 px-6 lg:px-8 shadow-sm hover:shadow-md transition-shadow duration-300 w-full md:w-fit">
          <span class="text-4xl lg:text-6xl font-black bg-gradient-to-r from-[#f04f23] to-[#ff7e5f] bg-clip-text text-transparent tracking-tighter">+<span id="exp-counter">1</span></span>
          <span class="text-slate-700 font-bold leading-tight text-[14px] lg:text-[16px] uppercase tracking-wide text-left">
            Años de<br/>experiencia
          </span>
        </div>
      </div>

    </div>

    {/* Nuestra Historia (Timeline) */}
    <div class="mt-12 lg:mt-20 relative">
      <div class="text-center mb-10 lg:mb-16">
        <h2 class="text-[22px] lg:text-[36px] font-black text-[#0d1624] tracking-tight uppercase mb-3 md:mb-4">
          NUESTRA HISTORIA
        </h2>
        <div class="w-16 h-[3px] bg-[#f04f23] mx-auto mb-4 lg:mb-6"></div>
        <p class="font-bold text-[#0d1624] text-[14px] lg:text-[18px]">
          La tecnología al alcance de todos
        </p>
      </div>

      <div class="relative max-w-4xl mx-auto pl-8 md:pl-0">
        {/* Línea vertical de tiempo */}
        <div class="absolute left-[15px] md:left-1/2 top-2 bottom-2 w-[3px] bg-slate-100 md:-translate-x-1/2 rounded-full"></div>
        
        <div class="space-y-12 text-slate-600 leading-relaxed text-[15px] lg:text-[16px]">
          {/* Hito 2014 */}
          <div class="relative flex flex-col md:flex-row md:justify-between items-start md:items-center w-full group">
            <div class="hidden md:block w-[45%] text-right pr-12">
              <strong class="text-3xl lg:text-4xl font-black text-transparent bg-clip-text bg-gradient-to-b from-[#f04f23] to-[#ff7e5f] transition-transform duration-300 group-hover:scale-105 inline-block">2014</strong>
            </div>
            <div class="absolute left-[-22px] md:left-1/2 w-5 h-5 rounded-full bg-[#f04f23] border-4 border-white shadow-md md:-translate-x-1/2 mt-1 md:mt-0 z-10 transition-transform duration-300 group-hover:scale-125"></div>
            <div class="md:w-[45%] pl-6 md:pl-12 bg-white/50 backdrop-blur-sm rounded-2xl p-6 shadow-[0_4px_20px_rgb(0,0,0,0.03)] border border-slate-50 hover:shadow-[0_8px_30px_rgb(0,0,0,0.06)] transition-shadow">
              <strong class="text-lg md:text-2xl font-black text-[#f04f23] block md:hidden mb-2 md:mb-3">2014</strong>
              El Sr. Zevallos y la Sra. Hernandez asumen el reto de romper el oligopolio del segmento, haciendo que se genere un mercado competitivo de alta calidad y precio justo para los clientes, dado que en esos años eran perjudicados por un servicio lejano y encarecido por la falta de competencia.
            </div>
          </div>
          
          {/* Hito 2015-2020 */}
          <div class="relative flex flex-col md:flex-row md:justify-between items-start md:items-center w-full group">
            <div class="md:w-[45%] md:text-right pl-6 md:pl-0 md:pr-12 md:order-1 order-2 bg-white/50 backdrop-blur-sm rounded-2xl p-6 shadow-[0_4px_20px_rgb(0,0,0,0.03)] border border-slate-50 hover:shadow-[0_8px_30px_rgb(0,0,0,0.06)] transition-shadow">
              <strong class="text-lg md:text-2xl font-black text-[#f04f23] block md:hidden mb-2 md:mb-3">2015 al 2020</strong>
              Se desarrolla una política de expansión y consolidación como una empresa capaz de ofrecer soluciones integrales en todo lo referente a procesos termodinámicos. En dicha etapa, la primera alianza se dio con el fabricante de quemadores Baite, fabricante de origen chino que nos dio su representación exclusiva para toda Sudamérica.
            </div>
            <div class="absolute left-[-22px] md:left-1/2 w-5 h-5 rounded-full bg-[#f04f23] border-4 border-white shadow-md md:-translate-x-1/2 mt-1 md:mt-0 z-10 transition-transform duration-300 group-hover:scale-125 order-1 md:order-2"></div>
            <div class="hidden md:block w-[45%] pl-12 md:order-3">
              <strong class="text-3xl lg:text-4xl font-black text-transparent bg-clip-text bg-gradient-to-b from-[#f04f23] to-[#ff7e5f] transition-transform duration-300 group-hover:scale-105 inline-block">2015-2020</strong>
            </div>
          </div>

          {/* Hito 2022 */}
          <div class="relative flex flex-col md:flex-row md:justify-between items-start md:items-center w-full group">
            <div class="hidden md:block w-[45%] text-right pr-12">
              <strong class="text-3xl lg:text-4xl font-black text-transparent bg-clip-text bg-gradient-to-b from-[#f04f23] to-[#ff7e5f] transition-transform duration-300 group-hover:scale-105 inline-block">2022</strong>
            </div>
            <div class="absolute left-[-22px] md:left-1/2 w-5 h-5 rounded-full bg-[#f04f23] border-4 border-white shadow-md md:-translate-x-1/2 mt-1 md:mt-0 z-10 transition-transform duration-300 group-hover:scale-125"></div>
            <div class="md:w-[45%] pl-6 md:pl-12 bg-white/50 backdrop-blur-sm rounded-2xl p-6 shadow-[0_4px_20px_rgb(0,0,0,0.03)] border border-slate-50 hover:shadow-[0_8px_30px_rgb(0,0,0,0.06)] transition-shadow">
              <strong class="text-lg md:text-2xl font-black text-[#f04f23] block md:hidden mb-2 md:mb-3">2022</strong>
              Con la marca Baite consolidada, se comienzan a estrechar lazos con fabricantes de equipos y accesorios europeos y norteamericanos. Es así como meses más tarde, la adquisición de productos de marcas como Siemens, Honeywell, Dungs y Pietro Fiorentini, fortaleció la capacidad de respaldar y dar soporte técnico a cualquier quemador de procedencia europea o asiática.
            </div>
          </div>

          {/* Hito 2023 */}
          <div class="relative flex flex-col md:flex-row md:justify-between items-start md:items-center w-full group">
            <div class="md:w-[45%] md:text-right pl-6 md:pl-0 md:pr-12 md:order-1 order-2 bg-white/50 backdrop-blur-sm rounded-2xl p-6 shadow-[0_4px_20px_rgb(0,0,0,0.03)] border border-slate-50 hover:shadow-[0_8px_30px_rgb(0,0,0,0.06)] transition-shadow">
              <strong class="text-lg md:text-2xl font-black text-[#f04f23] block md:hidden mb-2 md:mb-3">2023</strong>
              Las ventas y servicios se realizaban desde la virtualidad y solo se contaba con almacenes, sin embargo, surge la necesidad de implementar la primera tienda física y por ello se adquirieron siete tiendas comerciales en el centro industrial de Lima y el almacén central en el distrito de Carabayllo, llegando a un total de 3,200 m3 de área de almacenaje y venta.
            </div>
            <div class="absolute left-[-22px] md:left-1/2 w-5 h-5 rounded-full bg-[#f04f23] border-4 border-white shadow-md md:-translate-x-1/2 mt-1 md:mt-0 z-10 transition-transform duration-300 group-hover:scale-125 order-1 md:order-2"></div>
            <div class="hidden md:block w-[45%] pl-12 md:order-3">
              <strong class="text-3xl lg:text-4xl font-black text-transparent bg-clip-text bg-gradient-to-b from-[#f04f23] to-[#ff7e5f] transition-transform duration-300 group-hover:scale-105 inline-block">2023</strong>
            </div>
          </div>

          {/* Hito 2025 */}
          <div class="relative flex flex-col md:flex-row md:justify-between items-start md:items-center w-full group">
            <div class="hidden md:block w-[45%] text-right pr-12">
              <strong class="text-3xl lg:text-4xl font-black text-transparent bg-clip-text bg-gradient-to-b from-[#f04f23] to-[#ff7e5f] transition-transform duration-300 group-hover:scale-105 inline-block">2025</strong>
            </div>
            <div class="absolute left-[-22px] md:left-1/2 w-5 h-5 rounded-full bg-[#f04f23] border-4 border-white shadow-md md:-translate-x-1/2 mt-1 md:mt-0 z-10 transition-transform duration-300 group-hover:scale-125"></div>
            <div class="md:w-[45%] pl-6 md:pl-12 bg-white/50 backdrop-blur-sm rounded-2xl p-6 shadow-[0_4px_20px_rgb(0,0,0,0.03)] border border-slate-50 hover:shadow-[0_8px_30px_rgb(0,0,0,0.06)] transition-shadow">
              <strong class="text-lg md:text-2xl font-black text-[#f04f23] block md:hidden mb-2 md:mb-3">2025</strong>
              Heat Factory se convierte en la empresa #1 de Perú en venta de repuestos y accesorios para calderas y quemadores, con exportaciones a más de 20 países y representando a mas de 40 marcas. Hoy se puede afirmar con total certeza, que Heat Factory mantiene el stock más grande de quemadores en la región.
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* Misión y Visión */}
    <div class="mt-12 lg:mt-16 mb-8 lg:mb-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 relative">
        {/* Misión Card */}
        <div class="bg-white rounded-[2rem] p-10 lg:p-14 shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100 hover:-translate-y-2 hover:shadow-[0_20px_40px_rgb(0,0,0,0.08)] transition-all duration-300 relative overflow-hidden group">
          <div class="absolute top-0 left-0 w-full h-[3px] bg-gradient-to-r from-[#f04f23] to-[#ff7e5f] transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
          <h2 class="text-[20px] lg:text-[24px] font-black text-[#0d1624] tracking-tight uppercase mb-4">
            MISION
          </h2>
          <div class="w-16 h-[3px] bg-[#f04f23] mb-8"></div>
          <p class="text-slate-600 leading-relaxed text-[14px]">
            Ofrecer soluciones eficientes y de calidad, brindando comodidad y seguridad a nuestros clientes en cada producto y servicio de acuerdo a sus necesidades.
          </p>
        </div>

        {/* Visión Card */}
        <div class="bg-white rounded-[2rem] p-10 lg:p-14 shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100 hover:-translate-y-2 hover:shadow-[0_20px_40px_rgb(0,0,0,0.08)] transition-all duration-300 relative overflow-hidden group">
          <div class="absolute top-0 left-0 w-full h-[3px] bg-gradient-to-r from-[#0d1624] to-[#2a3c5a] transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
          <h2 class="text-[20px] lg:text-[24px] font-black text-[#0d1624] tracking-tight uppercase mb-4">
            VISION
          </h2>
          <div class="w-16 h-[3px] bg-[#f04f23] mb-8"></div>
          <p class="text-slate-600 leading-relaxed text-[14px]">
            Convertirnos en una empresa referente en la región brindando soluciones tecnológicas de combustion, por medio de un excepcional servicio a nuestros clientes.
          </p>
        </div>
      </div>
    </div>

    {/* Nuestros Valores */}
    <div class="mb-10 lg:mb-10 flex flex-col items-center bg-slate-50 py-10 lg:py-16 px-6 md:px-8 lg:px-20 rounded-[2.5rem] border border-slate-100 w-full">
      <div class="text-center mb-10 lg:mb-16">
        <h2 class="text-[20px] lg:text-[24px] font-black text-[#0d1624] tracking-tight uppercase mb-4">
          NUESTROS VALORES
        </h2>
        <div class="w-16 h-[3px] bg-[#f04f23] mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-12 w-full max-w-5xl">
        {/* Valor 1: El cliente es lo primero */}
        <div class="flex flex-col items-center text-center group bg-white p-5 md:p-4 lg:p-10 rounded-[1.5rem] lg:rounded-[2rem] shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-300">
          <div class="text-[#f04f23] mb-3 lg:mb-8 flex items-center justify-center h-16 lg:h-20 transform transition-transform duration-500 group-hover:scale-110 group-hover:-rotate-3">
            {/* SVG Hand holding heart exacto */}
            <svg viewBox="0 0 640 512" width="40" height="40" class="lg:w-[50px] lg:h-[50px]" fill="currentColor">
              <path d="M163.9 136.9c-29.4-29.8-29.4-78.2 0-108s77-29.8 106.4 0l17.7 18 17.7-18c29.4-29.8 77-29.8 106.4 0s29.4 78.2 0 108L310.5 240.1c-6.2 6.3-14.3 9.4-22.5 9.4s-16.3-3.1-22.5-9.4L163.9 136.9zM568.2 336.3c13.1 17.8 9.3 42.8-8.5 55.9L433.1 485.5c-23.4 17.2-51.6 26.5-80.7 26.5L192 512 32 512c-17.7 0-32-14.3-32-32l0-64c0-17.7 14.3-32 32-32l36.8 0 44.9-36c22.7-18.2 50.9-28 80-28l78.3 0 16 0 64 0c17.7 0 32 14.3 32 32s-14.3 32-32 32l-64 0-16 0c-8.8 0-16 7.2-16 16s7.2 16 16 16l120.6 0 119.7-88.2c17.8-13.1 42.8-9.3 55.9 8.5zM193.6 384c0 0 0 0 0 0l-.9 0c.3 0 .6 0 .9 0z"></path>
            </svg>
          </div>
          <p class="font-bold text-[#0d1624] text-[14px] lg:text-[15px]">El cliente es lo primero</p>
        </div>

        {/* Valor 2: Somos un solo equipo */}
        <div class="flex flex-col items-center text-center group bg-white p-5 md:p-4 lg:p-10 rounded-[1.5rem] lg:rounded-[2rem] shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-300">
          <div class="text-[#f04f23] mb-3 lg:mb-8 flex items-center justify-center h-16 lg:h-20 transform transition-transform duration-500 group-hover:scale-110">
            {/* SVG Users Group exacto */}
            <svg viewBox="0 0 640 512" width="48" height="48" class="lg:w-[60px] lg:h-[60px]" fill="currentColor">
              <path d="M144 0a80 80 0 1 1 0 160A80 80 0 1 1 144 0zM512 0a80 80 0 1 1 0 160A80 80 0 1 1 512 0zM0 298.7C0 239.8 47.8 192 106.7 192l42.7 0c15.9 0 31 3.5 44.6 9.7c-1.3 7.2-1.9 14.7-1.9 22.3c0 38.2 16.8 72.5 43.3 96c-.2 0-.4 0-.7 0L21.3 320C9.6 320 0 310.4 0 298.7zM405.3 320c-.2 0-.4 0-.7 0c26.6-23.5 43.3-57.8 43.3-96c0-7.6-.7-15-1.9-22.3c13.6-6.3 28.7-9.7 44.6-9.7l42.7 0C592.2 192 640 239.8 640 298.7c0 11.8-9.6 21.3-21.3 21.3l-213.3 0zM224 224a96 96 0 1 1 192 0 96 96 0 1 1 -192 0zM128 485.3C128 411.7 187.7 352 261.3 352l117.3 0C452.3 352 512 411.7 512 485.3c0 14.7-11.9 26.7-26.7 26.7l-330.7 0c-14.7 0-26.7-11.9-26.7-26.7z"></path>
            </svg>
          </div>
          <p class="font-bold text-[#0d1624] text-[14px] lg:text-[15px]">Somos un solo equipo</p>
        </div>

        {/* Valor 3: Pensamos en grande */}
        <div class="flex flex-col items-center text-center group bg-white p-5 md:p-4 lg:p-10 rounded-[1.5rem] lg:rounded-[2rem] shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-300">
          <div class="text-[#f04f23] mb-3 lg:mb-8 flex items-center justify-center h-16 lg:h-20 transform transition-transform duration-500 group-hover:scale-110 group-hover:rotate-3">
            {/* SVG Lightbulb exacto */}
            <svg viewBox="0 0 384 512" width="32" height="32" class="lg:w-[40px] lg:h-[40px]" fill="currentColor">
              <path d="M272 384c9.6-31.9 29.5-59.1 49.2-86.2c0 0 0 0 0 0c5.2-7.1 10.4-14.2 15.4-21.4c19.8-28.5 31.4-63 31.4-100.3C368 78.8 289.2 0 192 0S16 78.8 16 176c0 37.3 11.6 71.9 31.4 100.3c5 7.2 10.2 14.3 15.4 21.4c0 0 0 0 0 0c19.8 27.1 39.7 54.4 49.2 86.2l160 0zM192 512c44.2 0 80-35.8 80-80l0-16-160 0 0 16c0 44.2 35.8 80 80 80zM112 176c0 8.8-7.2 16-16 16s-16-7.2-16-16c0-61.9 50.1-112 112-112c8.8 0 16 7.2 16 16s-7.2 16-16 16c-44.2 0-80 35.8-80 80z"></path>
            </svg>
          </div>
          <p class="font-bold text-[#0d1624] text-[14px] lg:text-[15px]">Pensamos en grande</p>
        </div>
      </div>
    </div>

    {/* Nuestras Marcas */}
    <div class="mt-10 lg:mt-12 mb-0 lg:mb-0 w-full border-t border-gray-100 pt-10 lg:pt-12">
      <div class="text-center mb-10 lg:mb-16">
        <h2 class="text-[20px] lg:text-[24px] font-black text-[#0d1624] tracking-tight uppercase mb-4">
          NUESTRAS MARCAS
        </h2>
        <div class="w-16 h-[3px] bg-[#f04f23] mx-auto"></div>
      </div>

      {/* Grid de Marcas */}
      <div class="grid grid-cols-2 md:grid-cols-4 gap-x-8 gap-y-10 lg:gap-y-16 items-center justify-items-center w-full max-w-[1200px] mx-auto px-4">
        {[
          { name: "Honeywell", logo: "/marcas/honeywell.png" },
          { name: "McDonnell & Miller", logo: "/marcas/mcdonnell.png" },
          { name: "Baite", logo: "/marcas/baite.png" },
          { name: "Wayne", logo: "/marcas/wayne.png" },
          { name: "Beckett", logo: "/marcas/beckett.png" },
          { name: "Siemens", logo: "/marcas/siemens.png" },
          { name: "Ayvaz", logo: "/marcas/ayvaz.png" },
          { name: "United Brass Works", logo: "/marcas/united.png" },
          { name: "Everlasting Valve Company", logo: "/marcas/everlasting.png" },
          { name: "Resideo", logo: "/marcas/resideo.png" },
          { name: "Topog-E", logo: "/marcas/topog.png" },
          { name: "Power Flame Inc.", logo: "/marcas/powerflame.png" },
          { name: "Allanson", logo: "/marcas/allanson.png" },
          { name: "Belgas", logo: "/marcas/belgas.png" },
          { name: "Gems", logo: "/marcas/gems.png" },
          { name: "Suntec", logo: "/marcas/suntec.png" },
        ].map((marca) => (
          <div class="w-full flex justify-center p-4">
            <img 
              src={marca.logo} 
              alt={marca.name} 
              title={marca.name}
              class="max-h-12 lg:max-h-16 w-auto object-contain transform hover:scale-110 hover:drop-shadow-md transition-all duration-300"
            />
          </div>
        ))}
      </div>
    </div>
  </main>

  <script>
    const counterElement = document.getElementById('exp-counter');
    if (counterElement) {
      const target = 10;
      const duration = 1500; // 1.5 seconds es ideal para números pequeños
      
      // @ts-ignore
      const easeOutQuad = (t) => t * (2 - t);

      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          let startTime = 0;
          
          // @ts-ignore
          const animate = (currentTime) => {
            if (startTime === 0) startTime = currentTime;
            const progress = Math.min((currentTime - startTime) / duration, 1);
            
            // Math.round arregla el problema de quedarse pegado en el 9
            const currentVal = Math.round(easeOutQuad(progress) * (target - 1)) + 1;
            
            counterElement.innerText = currentVal.toString();
            
            if (progress < 1) {
              requestAnimationFrame(animate);
            } else {
              counterElement.innerText = target.toString();
            }
          };
          
          requestAnimationFrame(animate);
          observer.disconnect();
        }
      });
      observer.observe(counterElement);
    }
  </script>
</Layout>
