---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.tsx";
---

<Layout>
  <Header client:load />

  <main class="max-w-[1000px] mx-auto pt-8 pb-6 md:pb-16 px-4 md:px-8">
    
    <div class="bg-white rounded-[2rem] shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100 p-5 sm:p-8 md:p-12">
      <div class="mb-10 border-b border-slate-100 pb-8 flex flex-col md:flex-row items-center gap-6">
        <div class="flex-shrink-0">
          {/* Libro de Reclamaciones Icon */}
          <div class="w-16 h-16 md:w-24 md:h-24 bg-slate-50 border-2 border-slate-200 rounded-xl flex items-center justify-center relative overflow-hidden shadow-sm">
            <div class="absolute top-0 left-0 w-full h-2.5 md:h-4 bg-[#f04f23]"></div>
            <svg class="w-8 h-8 md:w-12 md:h-12 text-[#0d1624] mt-1.5 md:mt-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
          </div>
        </div>
        <div class="text-center md:text-left w-full">
          <h2 class="text-[18px] md:text-[20px] font-black text-[#0d1624] tracking-tight uppercase mb-2">Libro de Reclamaciones Virtual</h2>
          <p class="text-slate-600 text-[12px] md:text-[14px] leading-relaxed">
            Conforme a lo establecido en el Código de Protección y Defensa del Consumidor, contamos con un Libro de Reclamaciones a tu disposición. Llena el siguiente formulario y te responderemos a la brevedad posible.
          </p>
          <div class="mt-4 flex flex-col sm:flex-row justify-center md:justify-start items-center sm:items-stretch gap-3 md:gap-4 text-[11px] md:text-[13px]">
            <span class="bg-slate-100 text-slate-700 px-3 py-1.5 rounded-md font-semibold">RUC: 20613311808</span>
            <span class="bg-slate-100 text-slate-700 px-3 py-1.5 rounded-md font-semibold">Razón Social: GRUPO EMPRESARIAL ZEVALLOS S.A.C.</span>
          </div>
        </div>
      </div>

      <form id="complaintForm" class="space-y-8 md:space-y-12" novalidate>
        {/* Sección 1: Datos del Consumidor */}
        <section>
          <h3 class="flex flex-col md:flex-row items-center text-center md:text-left text-[14px] md:text-[16px] font-bold text-[#0d1624] mb-6 uppercase tracking-wide">
            <span class="bg-[#f04f23] text-white w-6 h-6 shrink-0 rounded-full flex items-center justify-center text-[13px] mb-2 md:mb-0 mr-0 md:mr-3">1</span>
            Identificación del Consumidor Reclamante
          </h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="md:col-span-2">
              <label class="block text-[13px] font-semibold text-slate-700 mb-2">Nombres y Apellidos Completos *</label>
              <input type="text" id="consumerName" name="consumerName" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-0 focus:border-[#f04f23] text-[14px]" placeholder="Ej: Juan Pérez García" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-slate-700 mb-2">Tipo de Documento *</label>
              <select id="documentType" name="documentType" required onchange="document.getElementById('documentNumber').value = ''" class="w-full pl-4 pr-10 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-0 focus:border-[#f04f23] text-[14px]">
                <option value="" disabled selected>Selecciona una opción</option>
                <option value="DNI">DNI</option>
                <option value="CE">Carnet de Extranjería</option>
                <option value="PAS">Pasaporte</option>
                <option value="RUC">RUC</option>
              </select>
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-slate-700 mb-2">Número de Documento *</label>
              <input type="text" id="documentNumber" name="documentNumber" required oninput="this.value = this.value.replace(/[^0-9]/g, '')" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-0 focus:border-[#f04f23] text-[14px]" placeholder="Ej: 12345678" />
            </div>
            <div class="md:col-span-2">
              <label class="block text-[13px] font-semibold text-slate-700 mb-2">Dirección de Domicilio *</label>
              <input type="text" id="address" name="address" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-0 focus:border-[#f04f23] text-[14px]" placeholder="Ej: Av. Javier Prado 1234, Lima" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-slate-700 mb-2">Teléfono / Celular *</label>
              <input type="tel" id="phone" name="phone" required oninput="this.value = this.value.replace(/[^0-9+() -]/g, '')" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-0 focus:border-[#f04f23] text-[14px]" placeholder="Ej: 987 654 321" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-slate-700 mb-2">Correo Electrónico *</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-0 focus:border-[#f04f23] text-[14px]" placeholder="Ej: correo@ejemplo.com" />
            </div>
          </div>
        </section>

        {/* Sección 2: Identificación del Bien */}
        <section>
          <h3 class="flex flex-col md:flex-row items-center text-center md:text-left text-[14px] md:text-[16px] font-bold text-[#0d1624] mb-6 uppercase tracking-wide">
            <span class="bg-[#f04f23] text-white w-6 h-6 shrink-0 rounded-full flex items-center justify-center text-[13px] mb-2 md:mb-0 mr-0 md:mr-3">2</span>
            Identificación del Bien Contratado
          </h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-[13px] font-semibold text-slate-700 mb-2">Tipo *</label>
              <select id="productType" name="productType" required class="w-full pl-4 pr-10 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-0 focus:border-[#f04f23] text-[14px]">
                <option value="" disabled selected>Selecciona una opción</option>
                <option value="Producto">Producto</option>
                <option value="Servicio">Servicio</option>
              </select>
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-slate-700 mb-2">Monto Reclamado (S/) *</label>
              <input type="number" step="0.01" id="amount" name="amount" required onwheel="this.blur()" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-0 focus:border-[#f04f23] text-[14px]" placeholder="Ej: 150.00" />
            </div>
            <div class="md:col-span-2">
              <label class="block text-[13px] font-semibold text-slate-700 mb-2">Descripción del Producto o Servicio *</label>
              <input type="text" id="productDescription" name="productDescription" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-0 focus:border-[#f04f23] text-[14px]" placeholder="Ej: Quemador a gas modelo X" />
            </div>
          </div>
        </section>

        {/* Sección 3: Detalle de la Reclamación */}
        <section>
          <h3 class="flex flex-col md:flex-row items-center text-center md:text-left text-[14px] md:text-[16px] font-bold text-[#0d1624] mb-6 uppercase tracking-wide">
            <span class="bg-[#f04f23] text-white w-6 h-6 shrink-0 rounded-full flex items-center justify-center text-[13px] mb-2 md:mb-0 mr-0 md:mr-3">3</span>
            Detalle de la Reclamación y Pedido del Consumidor
          </h3>
          <div class="grid grid-cols-1 gap-6">
            <div>
              <label class="block text-[13px] font-semibold text-slate-700 mb-3">Tipo de Reclamación *</label>
              <div class="flex flex-col sm:flex-row gap-6">
                <label class="flex items-start gap-3 cursor-pointer group">
                  <input type="radio" name="complaintType" value="Reclamo" required class="mt-1 w-4 h-4 text-[#f04f23] bg-slate-50 border-slate-300 focus:ring-[#f04f23]" />
                  <div>
                    <span class="block font-bold text-[#0d1624] text-[14px]">Reclamo</span>
                    <span class="block text-slate-500 text-[12px] mt-0.5">Disconformidad relacionada a los productos o servicios.</span>
                  </div>
                </label>
                <label class="flex items-start gap-3 cursor-pointer group">
                  <input type="radio" name="complaintType" value="Queja" required class="mt-1 w-4 h-4 text-[#f04f23] bg-slate-50 border-slate-300 focus:ring-[#f04f23]" />
                  <div>
                    <span class="block font-bold text-[#0d1624] text-[14px]">Queja</span>
                    <span class="block text-slate-500 text-[12px] mt-0.5">Malestar o descontento respecto a la atención al público.</span>
                  </div>
                </label>
              </div>
            </div>
            
            <div>
              <label class="block text-[13px] font-semibold text-slate-700 mb-2">Detalle de la reclamación *</label>
              <textarea id="complaintDetail" name="complaintDetail" required rows="4" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-0 focus:border-[#f04f23] text-[14px] resize-none" placeholder="Describa detalladamente el motivo de su reclamo o queja..."></textarea>
            </div>
            
            <div>
              <label class="block text-[13px] font-semibold text-slate-700 mb-2">Pedido del consumidor *</label>
              <textarea id="consumerRequest" name="consumerRequest" required rows="3" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-0 focus:border-[#f04f23] text-[14px] resize-none" placeholder="¿Qué solución espera obtener?"></textarea>
            </div>
          </div>
        </section>

        {/* Políticas y Envío */}
        <div class="pt-4 md:pt-6 border-t border-slate-100">
          <label class="flex items-start gap-3 mb-6 md:mb-8 cursor-pointer">
            <input type="checkbox" id="privacyPolicy" name="privacyPolicy" required class="mt-1 w-4 h-4 text-[#f04f23] bg-slate-50 border-slate-300 rounded focus:ring-[#f04f23]" />
            <span class="text-[13px] text-slate-600 leading-relaxed">
              Declaro que los datos consignados son correctos y fieles a la verdad. Asimismo, acepto las <button type="button" onclick="document.getElementById('privacyModal').showModal()" class="text-[#f04f23] underline hover:text-[#d0421c] cursor-pointer">Políticas de Privacidad</button> para el tratamiento de mis datos personales en la gestión de esta reclamación.
            </span>
          </label>
          
          <div id="successMessage" class="hidden bg-green-50 text-green-700 p-4 rounded-xl mb-6 text-sm font-medium border border-green-200">
            ✅ Su reclamo ha sido enviado exitosamente. En breve recibirá una copia en su correo electrónico.
          </div>
          
          <div id="errorMessage" class="hidden bg-red-50 text-red-700 p-4 rounded-xl mb-6 text-sm font-medium border border-red-200">
            ❌ Ocurrió un error al enviar el reclamo. Por favor intente nuevamente.
          </div>

          <div class="flex justify-end">
            <button id="submitBtn" type="submit" class="w-full sm:w-auto bg-[#0d1624] text-white font-bold text-[13px] md:text-[15px] py-3 md:py-4 px-6 md:px-10 rounded-xl shadow-lg hover:bg-[#1a2538] hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex items-center justify-center gap-2 md:gap-3 cursor-pointer">
              <span id="submitText">Enviar Reclamo / Queja</span>
              <svg id="submitIcon" class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </button>
          </div>
        </div>

      </form>

      <script>
        // ─── Helpers de Validación ───────────────────────────────────────────
        function showError(fieldId: string, message: string) {
          const field = document.getElementById(fieldId);
          if (!field) return;
          field.classList.add('border-red-400', 'bg-red-50');
          field.classList.remove('border-slate-200', 'bg-slate-50');
          let errorEl = field.parentElement?.querySelector('.field-error');
          if (!errorEl) {
            errorEl = document.createElement('p');
            errorEl.className = 'field-error text-red-500 text-[11px] mt-1 font-medium';
            field.parentElement?.appendChild(errorEl);
          }
          errorEl.textContent = message;
        }

        function clearError(fieldId: string) {
          const field = document.getElementById(fieldId);
          if (!field) return;
          field.classList.remove('border-red-400', 'bg-red-50');
          field.classList.add('border-slate-200', 'bg-slate-50');
          field.parentElement?.querySelector('.field-error')?.remove();
        }

        function clearAllErrors() {
          document.querySelectorAll('.field-error').forEach(el => el.remove());
          document.querySelectorAll('.border-red-400').forEach(el => {
            el.classList.remove('border-red-400', 'bg-red-50');
            el.classList.add('border-slate-200', 'bg-slate-50');
          });
        }

        // ─── Generación de Hash SHA-256 ──────────────────────────────────────
        async function generateHash(data: { consumerName: string; documentType: string; documentNumber: string; complaintType: string; complaintDetail: string }) {
          const timestamp = new Date().toISOString();
          const payload = [
            timestamp,
            data.consumerName,
            data.documentType,
            data.documentNumber,
            data.complaintType,
            data.complaintDetail,
          ].join('|');

          const encoder = new TextEncoder();
          const hashBuffer = await crypto.subtle.digest('SHA-256', encoder.encode(payload));
          const hashArray = Array.from(new Uint8Array(hashBuffer));
          const hashHex = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
          return { hash: hashHex, timestamp };
        }

        // ─── Validación del Formulario ───────────────────────────────────────
        function validateForm(data: {
          consumerName: string;
          documentType: string;
          documentNumber: string;
          address: string;
          phone: string;
          email: string;
          productType: string;
          amount: string;
          productDescription: string;
          complaintType: string;
          complaintDetail: string;
          consumerRequest: string;
          privacyPolicy?: string;
        }) {
          const errors: string[] = [];

          // Sección 1
          if (!data.consumerName || data.consumerName.trim().length < 3) {
            showError('consumerName', 'Ingrese su nombre completo (mínimo 3 caracteres).');
            errors.push('consumerName');
          } else clearError('consumerName');

          if (!data.documentType) {
            const sel = document.getElementById('documentType');
            sel?.classList.add('border-red-400', 'bg-red-50');
            sel?.classList.remove('border-slate-200', 'bg-slate-50');
            let err = sel?.parentElement?.querySelector('.field-error');
            if (!err) {
              err = document.createElement('p');
              err.className = 'field-error text-red-500 text-[11px] mt-1 font-medium';
              sel?.parentElement?.appendChild(err);
            }
            err.textContent = 'Seleccione un tipo de documento.';
            errors.push('documentType');
          } else clearError('documentType');

          let docError = '';
          const docNum = data.documentNumber ? data.documentNumber.trim() : '';

          if (!docNum) {
            docError = 'Ingrese su número de documento.';
          } else if (!/^[0-9]+$/.test(docNum)) {
            docError = 'El documento solo debe contener números.';
          } else {
            if (data.documentType === 'DNI' && docNum.length !== 8) {
              docError = 'El DNI debe tener exactamente 8 dígitos.';
            } else if (data.documentType === 'RUC' && docNum.length !== 11) {
              docError = 'El RUC debe tener exactamente 11 dígitos.';
            } else if (data.documentType === 'CE' && docNum.length !== 9) {
              docError = 'El Carnet de Extranjería debe tener 9 dígitos.';
            } else if (data.documentType === 'PAS' && docNum.length < 6) {
              docError = 'El Pasaporte debe tener al menos 6 dígitos.';
            }
          }

          if (docError) {
            showError('documentNumber', docError);
            errors.push('documentNumber');
          } else {
            clearError('documentNumber');
          }

          if (!data.address || data.address.trim().length < 5) {
            showError('address', 'Ingrese su dirección de domicilio.');
            errors.push('address');
          } else clearError('address');

          const phoneRegex = /^[+]?[\d\s\-()]{7,15}$/;
          if (!data.phone || !phoneRegex.test(data.phone.trim())) {
            showError('phone', 'Ingrese un número de teléfono válido.');
            errors.push('phone');
          } else clearError('phone');

          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          if (!data.email || !emailRegex.test(data.email.trim())) {
            showError('email', 'Ingrese un correo electrónico válido.');
            errors.push('email');
          } else clearError('email');

          // Sección 2
          if (!data.productType) {
            const sel = document.getElementById('productType');
            sel?.classList.add('border-red-400', 'bg-red-50');
            sel?.classList.remove('border-slate-200', 'bg-slate-50');
            let err = sel?.parentElement?.querySelector('.field-error');
            if (!err) {
              err = document.createElement('p');
              err.className = 'field-error text-red-500 text-[11px] mt-1 font-medium';
              sel?.parentElement?.appendChild(err);
            }
            err.textContent = 'Seleccione un tipo de bien.';
            errors.push('productType');
          } else clearError('productType');

          if (!data.amount || parseFloat(data.amount) <= 0) {
            showError('amount', 'Ingrese un monto reclamado válido (mayor a 0).');
            errors.push('amount');
          } else clearError('amount');

          if (!data.productDescription || data.productDescription.trim().length < 5) {
            showError('productDescription', 'Describa el producto o servicio (mínimo 5 caracteres).');
            errors.push('productDescription');
          } else clearError('productDescription');

          // Sección 3
          if (!data.complaintType) {
            const radioGroup = document.querySelector('[name="complaintType"]')?.closest('div');
            if (radioGroup && !radioGroup.querySelector('.field-error')) {
              const err = document.createElement('p');
              err.className = 'field-error text-red-500 text-[11px] mt-1 font-medium';
              err.textContent = 'Seleccione el tipo de reclamación.';
              radioGroup.appendChild(err);
            }
            errors.push('complaintType');
          } else {
            document.querySelector('[name="complaintType"]')?.closest('div')?.querySelector('.field-error')?.remove();
          }

          if (!data.complaintDetail || data.complaintDetail.trim().length < 20) {
            showError('complaintDetail', 'El detalle debe tener al menos 20 caracteres.');
            errors.push('complaintDetail');
          } else clearError('complaintDetail');

          if (!data.consumerRequest || data.consumerRequest.trim().length < 10) {
            showError('consumerRequest', 'Indique su pedido (mínimo 10 caracteres).');
            errors.push('consumerRequest');
          } else clearError('consumerRequest');

          if (!data.privacyPolicy) {
            const checkboxContainer = document.getElementById('privacyPolicy')?.closest('label');
            if (checkboxContainer && !checkboxContainer.parentElement?.querySelector('.field-error')) {
              const err = document.createElement('p');
              err.className = 'field-error text-red-500 text-[11px] mt-1 font-medium';
              err.textContent = 'Debe aceptar la declaración y políticas de privacidad para continuar.';
              checkboxContainer.parentElement?.appendChild(err);
            }
            errors.push('privacyPolicy');
          } else {
            const checkboxContainer = document.getElementById('privacyPolicy')?.closest('label');
            checkboxContainer?.parentElement?.querySelector('.field-error')?.remove();
          }

          return errors;
        }

        // ─── Submit ──────────────────────────────────────────────────────────
        const form = document.getElementById('complaintForm') as HTMLFormElement | null;
        const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement | null;
        const submitText = document.getElementById('submitText');
        const submitIcon = document.getElementById('submitIcon');
        const successMessage = document.getElementById('successMessage');
        const errorMessage = document.getElementById('errorMessage');

        if (form) {
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            clearAllErrors();

            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries()) as {
              consumerName: string; documentType: string; documentNumber: string;
              address: string; phone: string; email: string; productType: string;
              amount: string; productDescription: string; complaintType: string;
              complaintDetail: string; consumerRequest: string;
              [key: string]: string;
            };

            // Validar
            const errors = validateForm(data);
            if (errors.length > 0) {
              const firstErrorField = document.getElementById(errors[0]) || document.querySelector(`[name="${errors[0]}"]`);
              firstErrorField?.scrollIntoView({ behavior: 'smooth', block: 'center' });
              return;
            }

            // Generar hash de integridad
            const { hash, timestamp } = await generateHash(data);
            data.hash = hash;
            data.timestamp = timestamp;

            // UI Loading state
            if (submitBtn) submitBtn.disabled = true;
            if (submitText) submitText.textContent = 'Enviando...';
            if (submitIcon) submitIcon.classList.add('hidden');
            if (successMessage) successMessage.classList.add('hidden');
            if (errorMessage) errorMessage.classList.add('hidden');

            try {
              const res = await fetch('/api/reclamaciones', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
              });

              if (res.ok) {
                if (successMessage) {
                  successMessage.innerHTML = `✅ Su reclamo ha sido enviado exitosamente. En breve recibirá una copia en su correo.<br><span class="text-[11px] font-mono text-green-600 mt-1 block">Código de validez: ${hash.substring(0, 16).toUpperCase()}</span>`;
                  successMessage.classList.remove('hidden');
                  window.scrollTo({ top: successMessage.offsetTop - 100, behavior: 'smooth' });
                }
                form.reset();
              } else {
                if (errorMessage) errorMessage.classList.remove('hidden');
              }
            } catch (error) {
              console.error(error);
              if (errorMessage) errorMessage.classList.remove('hidden');
            } finally {
              if (submitBtn) submitBtn.disabled = false;
              if (submitText) submitText.textContent = 'Enviar Reclamo / Queja';
              if (submitIcon) submitIcon.classList.remove('hidden');
            }
          });
        }
      </script>
    </div>

    {/* Modal de Políticas de Privacidad */}
    <dialog id="privacyModal" class="bg-white rounded-2xl shadow-2xl p-0 w-[90%] max-w-2xl backdrop:bg-slate-900/60 backdrop:backdrop-blur-sm fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 m-0 border-0 z-50">
      <div class="p-4 sm:p-5 md:p-8 max-h-[85vh] overflow-y-auto">
        <div class="flex justify-between items-center mb-3 md:mb-6">
          <h3 class="text-[16px] md:text-[18px] font-bold text-[#0d1624]">Políticas de Privacidad</h3>
          <button type="button" onclick="document.getElementById('privacyModal').close()" class="text-slate-400 hover:text-[#f04f23] transition-colors focus:outline-none">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
          </button>
        </div>
