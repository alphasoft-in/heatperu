---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
export interface Props {
  title?: string;
  description?: string;
  image?: string;
  keywords?: string;
}

const defaultKeywords = "quemadores peru, quemadores de gas y petroleo peru, quemadores de gas industriales, quemadores de petroleo industriales, quemadores baite, quemadores baltur, quemadores power flame, quemadores de gas baite, quemadores de petroleo baite, quemadores duales power flame, repuesto de quemadores peru, repuesto de calderas peru, valvulas para calderas, valvulas kunkle, valvulas de seguridad kunkle, bomba de agua para calderas, valvulas united brass, valvulas reguladoras de presion, reguladores de presion, reguladores de presion de vapor, reguladores united brass, valvulas everlasting, valvula de purga para calderas, valvula de purga united brass, valvulas para purga de calderas, manometros, termometros, bomba de petroleo, bomba de petroleo suntec, bomba suntec, sistemas de combustion, reparacion de calderas, empaquetaduras para calderas, empaquetaduras topog, columnas de nivel de agua peru, mcdonnell miller peru, honeywell peru, siemens peru, programadores honeywell, programadores siemens, resina cationica, resina cationica lewatit, valvulas para gas, reguladores de presion de gas, reguladores de gas, quemador wayne peru, quemador beckett peru, quemador de gas wayne, quemador de petroleo beckett, toberas para quemadores, toberas para ablandadores, transformadores de ignicion, transformadores allanson, controles para hornos y calderas, mantenimiento de calderas, calderas industriales para biogas, calderas industriales para industria textil, calderas industriales para mineria, instalacion de sistemas de combustion, instalacion de sistema slate honeywell, quemadores duales gas y petroleo, conversion de calderas a gas natural, conversion de calderas a biogas, quemadores de tiro forzado, proveedores de repuestos para calderas, proveedores de quemadores industriales, proveedores de valvulas para calderas, valvulas de paso ondulado, valvulas de paso ondulado peru, valvulas apollo, valvulas de bola, servomotores para quemador, proveedores de calderas, proveedores de repuestos y valvulas, repuestos de quemador power flame, repuestos de quemador baite, repuestos de quemador beckett, valvulas check united brass, valvulas de purga united brass, valvulas reguladoras united brass, united brass peru, topog peru";

const { 
  title = "Heat Factory - Alta Tecnología en Calderas y Quemadores",
  description = "Especialistas en venta, mantenimiento y automatización de calderas y quemadores industriales en Perú. Más de 10 años de experiencia.",
  image = "/bc-servicios.jpeg",
  keywords = defaultKeywords
} = Astro.props;
---
<!doctype html>
<html lang="es" class="overflow-x-hidden w-full">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/logoheat.png" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />

		<!-- Open Graph / Facebook / WhatsApp -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:site_name" content="Heat Factory" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />
	</head>
	<body class="overflow-x-hidden w-full">
		<slot />
		<Footer />
		
		<!-- Floating WhatsApp Button -->
		<a 
			href="https://wa.me/51967083176" 
			target="_blank" 
			rel="noopener noreferrer"
			class="fixed bottom-6 right-6 z-50 bg-[#25D366] text-white p-3.5 md:p-4 rounded-full shadow-[0_4px_12px_rgba(37,211,102,0.4)] hover:bg-[#20b858] hover:scale-110 hover:shadow-[0_6px_16px_rgba(37,211,102,0.5)] transition-all duration-300 flex items-center justify-center cursor-pointer group"
			aria-label="Contactar por WhatsApp"
		>
			<svg class="w-7 h-7 md:w-8 md:h-8" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
				<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
			</svg>
		</a>
	</body>
</html>
